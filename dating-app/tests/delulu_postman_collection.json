      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target_user_id\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/connections/request",
          "host": ["{{baseUrl}}"],
