{
  "info": {
    "name": "Delulu Dating App API Collection",
    "description": "Comprehensive API collection for testing Delulu endpoints: Auth, Discover, Connections, Messaging, Icebreakers, and Security.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Auth - Send Verification Email / OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lakshit.24bce11263@vitbhopal.ac.in\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/send-verification-email",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "send-verification-email"]
        }
      }
    },
    {
      "name": "Auth - User Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"wanderlust_amy\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "login"]
        }
      }
    },
    {
      "name": "Auth - Get Current Session Profile",
      "request": {
        "method": "GET",
