# =============================================================================
# Delulu Dating App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required:  SESSION_SECRET, FIREBASE_*, SUPABASE_*, BREVO_API_KEY
# Optional:  PORT, LOG_LEVEL, NODE_ENV, VAPID_*, GMAIL_USER
# =============================================================================


# --- Server ------------------------------------------------------------------

# Port the Express server listens on (default: 3000)
# PORT=3000

# Pino log level (default: 'info'). Options: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# Node environment (default: none). Set to 'production' for HTTPS redirect and secure cookies
# NODE_ENV=development

# REQUIRED - Session encryption secret (48+ random hex bytes).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_your_generated_secret


# --- Firebase Admin SDK (Authentication + Firestore) -------------------------

# Firebase project ID (from service account JSON)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase service account client email (from service account JSON)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# IMPORTANT - Firebase private key (from service account JSON).
# Wrap in double quotes if it contains \n sequences.
# Example: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Web SDK API Key (for client-side Firestore listener). Optional, polling fallback if unset.
# Get it from: Firebase Console > Project Settings > General > Web API Key
# FIREBASE_API_KEY=your-firebase-web-api-key

# Firebase Auth Domain (optional, defaults from project ID)
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Storage Bucket (optional, defaults from project ID)
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com


# --- Supabase (Messages Database) ---------------------------------------------

# REQUIRED - Supabase project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# REQUIRED - Supabase service_role key (NOT the anon public key).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# --- Brevo (Transactional Email) ----------------------------------------------

# REQUIRED - Brevo API v3 key (starts with xkeysib-)
BREVO_API_KEY=xkeysib-your-brevo-api-key

# Sender email (defaults to delulu.college.dating@gmail.com)
# GMAIL_USER=delulu.college.dating@gmail.com


# --- Web Push Notifications (VAPID Keys) --------------------------------------

# Generate with: npx web-push generate-vapid-keys
# If unset, push notifications are disabled but the app still works.
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
